# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL)
# For local Docker: postgresql://postgres:postgres@localhost:5432/college_erp?schema=public
# For Production: Replace with your secure production database connection URL
DATABASE_URL="postgresql://username:password@host:port/database_name?schema=public"

# Authentication Security (JWT Tokens)
# Replace with a long, cryptographically strong random string in production
JWT_SECRET="your_jwt_secret_key_minimum_32_characters"
JWT_EXPIRES_IN="7d"
